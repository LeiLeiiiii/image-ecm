<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunyard.module.system.mapper.SysRoleUserMapper">
    <select id="selectListAddUserName" resultType="com.sunyard.module.system.api.dto.SysRoleUserDTO">
        SELECT
            a.id,
            a.role_id,
            a.user_id,
            b.login_name AS userName,
            b.inst_id,
            b.dept_id
        FROM sys_role_user a
            LEFT JOIN sys_user b ON b.user_id = a.user_id
        WHERE
            a.is_deleted = 0
        <if test="roleIds != null and !roleIds.isEmpty()">
            AND a.role_id IN
            <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
                #{roleId}
            </foreach>
        </if>
        <if test="relateUserName != null and relateUserName != ''">
            AND b.login_name LIKE  CONCAT('%', #{relateUserName}, '%')
        </if>
    </select>

    <select id="selectListByUserIdList" resultType="com.sunyard.module.system.dto.SysRoleUserListDTO">
        SELECT
            a.role_id,
            b.name AS roleName,
            a.user_id
        FROM sys_role_user a
            LEFT JOIN sys_role b ON a.role_id = b.role_id
        WHERE a.user_id in
        <foreach collection="list" open="(" close=")" separator="," item="userId">
            #{userId}
        </foreach>
            AND a.is_deleted = 0
    </select>
</mapper>
