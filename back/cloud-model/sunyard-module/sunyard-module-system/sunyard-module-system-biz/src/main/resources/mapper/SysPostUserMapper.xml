<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunyard.module.system.mapper.SysPostUserMapper">

    <select id="searchPostUserByCondition" resultType="com.sunyard.module.system.api.dto.SysUserDTO">
        SELECT
            b.*
        FROM sys_post_user a,
             sys_user b
        WHERE
            a.user_id = b.user_id
            AND b.is_deleted = 0
            AND a.is_deleted = 0
            <if test="sysPostDTO.postId != null">
                AND a.post_id = #{sysPostDTO.postId}
            </if>
            <if test="sysPostDTO.instId != null">
                AND b.inst_id = #{sysPostDTO.instId}
            </if>
            <if test="sysPostDTO.deptId != null">
                AND b.dept_id = #{sysPostDTO.deptId}
            </if>
    </select>

    <select id="selectListByUserIdList" resultType="com.sunyard.module.system.dto.SysPostUserListDTO">
        SELECT
            a.post_id,
            b.name AS postName,
            a.user_id
        FROM sys_post_user a
            LEFT JOIN sys_post b ON a.post_id = b.post_id
        WHERE a.user_id in
        <foreach collection="list" open="(" close=")" separator="," item="userId">
            #{userId}
        </foreach>
        AND a.is_deleted = 0
    </select>
</mapper>
