<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sunyard.sunafm.mapper.AfmApiDataMapper">

    <insert id="insertBatch" parameterType="java.util.List">
        insert into afm_api_data(`id`, `status`,
        `request_params`,`retry_num`,`create_time`,`is_deleted`)
        values
        <foreach collection="list" item="it" separator=",">
            (#{it.id}, #{it.status}, #{it.requestParams},#{it.retryNum},
            #{it.createTime},#{it.isDeleted})
        </foreach>
    </insert>

</mapper>
