    <select id="selectFileAndAppcode" resultType="com.sunyard.ecm.dto.ecm.EcmFileInfoDTO" databaseId="oracle">
        SELECT a.*, b.app_code as appCode
        FROM ecm_file_info a
        LEFT JOIN ecm_busi_info b on a.busi_id = b.busi_id
        WHERE 1=1
        <!-- 单独判断开始时间 -->
        <if test="createTimeStart != null and createTimeStart != ''">
            AND a.create_time &gt;= TO_DATE(#{createTimeStart}, 'YYYY-MM-DD HH24:MI:SS')
        </if>
        <!-- 单独判断结束时间 -->
        <if test="createTimeEnd != null and createTimeEnd != ''">
            AND a.create_time &lt;= TO_DATE(#{createTimeEnd}, 'YYYY-MM-DD HH24:MI:SS')
        </if>
    </select>

    <select id="selectDocFileNums" resultType="com.sunyard.ecm.vo.DocFileNumVO">
        select count(fileId) fileSum, docCode, docName from (
        select f.file_id fileId,f.doc_code docCode, d.doc_name docName from ecm_file_info f
        left join ecm_doc_def d on f.doc_code = d.doc_code where f.busi_id = #{busiId} and f.state = 0
                                                           ) a group by  docCode, docName
    </select>
</mapper>
